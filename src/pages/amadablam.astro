---
import SectionBase from "../components/amadablam/SectionBase.astro";
import SectionDominaElGrado from "../components/amadablam/SectionDominaElGrado.astro";
import SectionInstalaciones from "../components/amadablam/SectionInstalaciones.astro";
import SectionLaCima from "../components/amadablam/SectionLaCima.astro";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Club Alpino Ama Dablam | The Ultimate Ascent</title>
    <link rel="icon" type="image/svg" href="/amadablam/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Host+Grotesk:ital,wght@0,300..800;1,300..800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    {/* Loader Overlay */}
    <div id="amadablam-loader" class="ama-loader">
      <div class="loader-text-container">
        <div class="loader-text outline">Ama Dablam</div>
        <div class="loader-text solid" id="ama-progress-bar">Ama Dablam</div>
      </div>
    </div>

    {/* Watermark ExtruDev — centrado, no interactivo */}
    <div class="extrudev-watermark" aria-hidden="true">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="4 17 10 11 4 5"></polyline>
        <line x1="12" y1="19" x2="20" y2="19"></line>
      </svg>
    </div>

    <main id="climb-container" class="locked">
      {/* Fondo dinámico con parallax */}
      <div id="dynamic-bg" class="bg-climb-wall zoom-out-start"></div>

      <div id="climb-content" class="content-hidden">
        {/* Navegación lateral (oculta en mobile) */}
        <nav class="fixed-nav">
          <ul class="nav-links">
            <li>
              <a href="#base" class="nav-item active" data-target="base">
                <span class="nav-text">Base</span>
              </a>
            </li>
            <li>
              <a href="#high" class="nav-item" data-target="high">
                <span class="nav-text">Instalaciones</span>
              </a>
            </li>
            <li>
              <a href="#low" class="nav-item" data-target="low">
                <span class="nav-text">Domina el Grado</span>
              </a>
            </li>
            <li>
              <a href="#summit" class="nav-item" data-target="summit">
                <span class="nav-text">¡La Cima!</span>
              </a>
            </li>
          </ul>
          {/* Barra de progreso */}
          <div class="progress-track">
            <div id="progress-bar" class="progress-bar"></div>
          </div>
        </nav>

        {/* Secciones */}
        <SectionLaCima />
        <SectionDominaElGrado />
        <SectionInstalaciones />
        <SectionBase />
      </div>
    </main>

    <script>
      import Lenis from "lenis";

      const isDesktop = () =>
        window.innerWidth >= 1024 &&
        !window.matchMedia("(pointer: coarse)").matches;

      const container = document.getElementById(
        "climb-container",
      ) as HTMLElement;
      const bg = document.getElementById("dynamic-bg") as HTMLElement | null;
      const progressBar = document.getElementById(
        "progress-bar",
      ) as HTMLElement | null;
      const progressTrack = document.querySelector(
        ".progress-track",
      ) as HTMLElement | null;
      const sections = document.querySelectorAll("section");

      if (!container) throw new Error("climb-container no encontrado");

      function syncProgressTrackHeight() {
        const navItems = Array.from(
          document.querySelectorAll(".fixed-nav .nav-item"),
        ) as HTMLElement[];
        if (!progressTrack || navItems.length < 2) return;
        const first = navItems[0].getBoundingClientRect();
        const last = navItems[navItems.length - 1].getBoundingClientRect();
        const h = Math.abs(
          last.top + last.height / 2 - (first.top + first.height / 2),
        );
        progressTrack.style.height = `${h}px`;
      }

      function onScroll(scrollTop: number) {
        const totalHeight = container.scrollHeight - container.clientHeight;
        const scrollPercent = scrollTop / totalHeight;

        if (progressBar) {
          progressBar.style.height = `${(1 - scrollPercent) * 100}%`;
        }
        if (bg) {
          bg.style.backgroundPosition = `center ${scrollPercent * 100}%`;
        }
        sections.forEach((sec) => {
          const rect = sec.getBoundingClientRect();
          if (rect.top >= 0 && rect.top < window.innerHeight / 2) {
            updateNavActive(sec.getAttribute("id") || "base");
          }
        });
      }

      function updateNavActive(id: string) {
        document.querySelectorAll(".nav-item").forEach((item) => {
          item.classList.remove("active");
          if (item.getAttribute("data-target") === id)
            item.classList.add("active");
        });
      }

      document.querySelectorAll(".nav-item").forEach((item) => {
        item.addEventListener("click", (e) => {
          e.preventDefault();
          const targetId = item.getAttribute("data-target");
          if (!targetId) return;
          const targetEl = document.getElementById(targetId);
          if (!targetEl) return;

          if (lenis) {
            lenis.scrollTo(targetEl, { offset: 0 });
          } else {
            targetEl.scrollIntoView({ behavior: "smooth" });
          }
        });
      });

      let lenis: InstanceType<typeof Lenis> | null = null;
      let rafId = 0;

      function initLenis() {
        if (lenis) return;
        lenis = new Lenis({
          wrapper: container,
          duration: 1.8,
          wheelMultiplier: 0.3,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          smoothWheel: true,
        });
        lenis.on("scroll", ({ scroll }: { scroll: number }) =>
          onScroll(scroll),
        );

        function raf(time: number) {
          lenis!.raf(time);
          rafId = requestAnimationFrame(raf);
        }
        rafId = requestAnimationFrame(raf);
      }

      function destroyLenis() {
        if (!lenis) return;
        cancelAnimationFrame(rafId);
        lenis.destroy();
        lenis = null;
        container.addEventListener("scroll", nativeScroll);
      }

      function nativeScroll() {
        onScroll(container.scrollTop);
      }

      // --- LOGICA DEL PRELOADER ---
      const loaderOverlay = document.getElementById("amadablam-loader");
      const progressBarEl = document.getElementById("ama-progress-bar");

      let loadProgress = 0;
      let isWindowLoaded = false;
      let isLoaderFinished = false;

      function simulateProgress() {
        if (!progressBarEl) return;
        const incr = Math.random() * 15 + 8; // Faster step ~10 total steps
        loadProgress += incr;

        // Pausar al 90% esperando recursos de la carga real
        if (loadProgress >= 90 && !isWindowLoaded) {
          loadProgress = 90;
        }
        if (loadProgress > 100) loadProgress = 100;

        progressBarEl.style.width = `${loadProgress}%`;

        if (loadProgress < 100) {
          const pause = Math.random() * 150 + 50; // media de ~100ms
          setTimeout(simulateProgress, pause);
        } else {
          finishLoader();
        }
      }

      function finishLoader() {
        if (isLoaderFinished) return;
        isLoaderFinished = true;
        setTimeout(() => {
          if (loaderOverlay) loaderOverlay.style.opacity = "0";

          // Esperamos a que el preloader se haya desvanecido casi del todo para hacer el zoom
          setTimeout(() => {
            if (bg) bg.classList.remove("zoom-out-start");
          }, 600);

          setTimeout(() => {
            if (loaderOverlay) loaderOverlay.style.display = "none";
          }, 800);

          // Mostramos el contenido de la web un poco ANTES de que termine el zoom
          // Soluciona la sensación de "retraso" al fluir con el último tramo de la animación
          setTimeout(() => {
            const content = document.getElementById("climb-content");
            if (content) {
              content.classList.remove("content-hidden");
            }
          }, 1600);

          // Liberamos el scroll y arreglamos el Parallax
          setTimeout(() => {
            container.classList.remove("locked");

            // FUNDAMENTAL: Eliminar la transición de 2.5s del background.
            // Si la dejamos, el Parallax intentará tardar 2.5s en cada pixel de scroll.
            if (bg) {
              bg.style.transition = "none";
            }
          }, 3100);
        }, 400); // pequeña pausa en 100%
      }

      // Arrancamos la simulación del loader
      setTimeout(simulateProgress, 50);

      window.addEventListener("load", () => {
        setTimeout(() => {
          container.scrollTop = container.scrollHeight;
          syncProgressTrackHeight();

          isWindowLoaded = true;

          // Si el loader se pausó, terminarlo
          if (loadProgress >= 90 && loadProgress < 100) {
            loadProgress = 100;
            if (progressBarEl) progressBarEl.style.width = "100%";
            finishLoader();
          }

          if (isDesktop()) {
            initLenis();
          } else {
            container.addEventListener("scroll", nativeScroll);
          }
        }, 150);
      });

      window.addEventListener("resize", () => {
        syncProgressTrackHeight();
        if (isDesktop()) {
          container.removeEventListener("scroll", nativeScroll);
          initLenis();
        } else {
          destroyLenis();
          container.addEventListener("scroll", nativeScroll);
        }
      });
    </script>
  </body>
</html>

<style is:global>
  /* ── Fuentes ─────────────────────────────────────────── */
  @font-face {
    font-family: "MadeInfinity";
    src: url("/amadablam/font/MADEINFINITYPersonalUse-Black.otf");
    font-weight: 900;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: "MadeInfinity-Outline";
    src: url("/amadablam/font/MADEINFINITYOutlinePersonalUse-Black.otf");
    font-weight: 900;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: "MadeInfinity-Beside";
    src: url("/amadablam/font/MADEINFINITYBesidePersonalUse-Black.otf");
    font-weight: 900;
    font-style: normal;
    font-display: swap;
  }

  /* ── Reset anchors ───────────────────────────────────── */
  a,
  a:visited,
  a:hover,
  a:active {
    text-decoration: none;
    color: inherit;
  }

  :root {
    --clr-dark: #003049;
    --clr-contrast: #d62828;
    --clr-accent: #f77f00;
    --clr-main: #fcbf49;
    --clr-text: #ffffff;
    --clr-text-muted: rgba(255, 255, 255, 0.5);
    --clr-surface: rgba(0, 48, 73, 0.78);
    --clr-overlay: rgba(0, 0, 0, 0.45);
    --clr-border: rgba(255, 255, 255, 0.12);
    --font-display: "MadeInfinity", sans-serif;
    --font-outline: "MadeInfinity-Outline", sans-serif;
    --font-beside: "MadeInfinity-Beside", sans-serif;
    --font-body: "Host Grotesk", sans-serif;
    --nav-right: 2rem;
  }

  /* ── Reset ───────────────────────────────────────────── */
  html,
  body {
    height: 100%;
    margin: 0;
    padding: 0;
    overflow-x: hidden;
    font-family: var(--font-body);
    color: var(--clr-text);
    background-color: transparent;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6,
  .top-badge,
  .main-title,
  .section-title {
    font-family: "MadeInfinity", "Host Grotesk", sans-serif !important;
    font-weight: 900;
    letter-spacing: -0.01em;
  }

  /* ── Animaciones ─────────────────────────────────────── */
  @keyframes float {
    0% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-30px);
    }
    100% {
      transform: translateY(0px);
    }
  }

  .animate-float {
    animation: float 2s ease-in-out infinite;
  }

  #climb-container {
    height: 100vh;
    overflow-y: scroll;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  #climb-container.locked {
    overflow: hidden !important;
  }

  #climb-container::-webkit-scrollbar {
    display: none;
  }

  /* ── Secciones ───────────────────────────────────────── */
  section {
    min-height: 100dvh;
    height: auto; /* Dejar crecer según contenido nativo */
    padding: 3.5rem 0; /* Mobile First: Padding protector para móvil */
    box-sizing: border-box;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
  }

  @media (min-width: 768px) {
    section {
      padding: 6rem 0; /* Padding Tablet */
    }
  }

  @media (min-width: 1024px) {
    section {
      height: 100vh;
      padding: 0;
    }
  }

  /* ── Shared layout ───────────────────────────────────── */
  .content-container {
    max-width: 1152px;
    width: 100%;
    padding-left: 1rem;
    padding-right: 1.5rem;
    box-sizing: border-box;
  }

  @media (min-width: 768px) {
    .content-container {
      padding-left: 2rem;
      padding-right: 3rem;
    }
  }

  @media (min-width: 1024px) {
    .content-container {
      padding: 0 1.5rem;
    }
  }
</style>

<style>
  /* ── Watermark ExtruDev ──────────────────────────────── */
  .extrudev-watermark {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 40vw;
    height: 40vh;
    z-index: 999;
    pointer-events: none;
    opacity: 0.4;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .extrudev-watermark svg {
    width: 100%;
    height: 100%;
  }

  /* ── Ocultar / Mostrar contenido tras animación ──────── */
  #climb-content {
    opacity: 1;
    transition: opacity 0.5s ease-in-out;
  }
  .content-hidden {
    opacity: 0 !important;
    pointer-events: none;
  }

  /* ── Fondo dinámico ──────────────────────────────────── */
  .bg-climb-wall {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: var(--clr-dark);
    background-image: url("/amadablam/bg-climb-wall.jpg");
    background-repeat: no-repeat;
    background-size: auto 250vh; /* Final Móvil: Zoom extremo */
    background-position: center bottom; /* Final General: Anclados en la base */
    z-index: -2;
    /* Al poner ambas agrupadas, nunca se sobreescriben */
    transition:
      background-size 2.5s cubic-bezier(0.65, 0, 0.35, 1),
      background-position 2.5s cubic-bezier(0.65, 0, 0.35, 1);
  }

  .bg-climb-wall.zoom-out-start {
    /* Móvil: Para que el navegador anime, tiene que ir de valor a valor. 120vh evita bordes blancos */
    background-size: auto 120vh;
  }

  @media (min-width: 768px) {
    .bg-climb-wall {
      background-size: 100vw auto;
      background-position: center bottom; /* Final Desktop: Base de pared */
      transition: background-position 2.5s cubic-bezier(0.65, 0, 0.35, 1);
    }
    .bg-climb-wall.zoom-out-start {
      background-size: 100vw auto;
      background-position: center top; /* Inicio Desktop: Cima (hace pan hacia base) */
    }
  }

  /* ── Navegación lateral derecha ──────────────────────── */
  .fixed-nav {
    position: fixed;
    right: var(--nav-right);
    top: 50%;
    transform: translateY(-50%);
    z-index: 50;
    display: flex;
    flex-direction: row;
    align-items: flex-end;
    gap: 1.25rem;
  }

  .nav-links {
    list-style: none;
    display: flex;
    flex-direction: column-reverse;
    gap: 8rem;
    margin: 0;
    padding: 0;
    text-align: right;
  }

  .nav-item {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1rem;
    text-decoration: none;
    color: var(--clr-text-muted);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    white-space: nowrap;
    transition: all 0.3s ease;
  }

  .nav-dot {
    display: none; /* Oculto en desktop por defecto */
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
  }

  .nav-item:hover {
    color: var(--clr-text);
  }

  .nav-item.active {
    color: var(--clr-main);
    font-weight: 700;
    scale: 1.25;
    transform-origin: right center;
  }

  /* ── Riel de progreso ────────────────────────────────── */
  .progress-track {
    position: relative;
    width: 5px;
    height: 450px;
    background-color: rgba(255, 255, 255, 0.15);
    border-radius: 2px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .progress-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 0%;
    background-color: var(--clr-main);
    border-radius: 2px;
    transition: height 0.15s ease;
  }

  /* ── Versión Tablets y Móviles ───────────────────────────── */
  @media (max-width: 1023px) {
    .fixed-nav {
      right: 0;
      top: 0;
      transform: translateY(0);
      height: 100dvh;
      align-items: stretch;
      gap: 0;
    }

    .nav-links {
      display: none !important; /* Asegurar eliminación total de los puntos y textos */
    }

    .nav-item {
      padding: 1rem;
      scale: 1 !important; /* Desactivar scale de desktop */
    }

    .nav-text {
      display: none; /* Ocular textos */
    }

    .nav-dot {
      display: none !important; /* Eliminados por completo en responsive */
    }

    .nav-item.active .nav-dot {
      display: none !important;
    }

    .progress-track {
      height: 100dvh !important; /* 100dvh obligatorio */
      width: 10px; /* Un poco mas ancho para que se toque con el dedo si se quiere */
      border-radius: 0; /* Sin curvas, va de lado a lado */
      margin-right: 0px;
      box-shadow: none !important;
    }
  }

  /* ── Loader Overlay y Modificador del Logo ───────────────────────────── */
  .ama-loader {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: var(--clr-dark);
    z-index: 9999;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: opacity 0.8s ease;
  }
  .loader-text-container {
    position: relative;
    font-size: 3rem;
    font-family: var(--font-display);
    text-transform: uppercase;
    font-weight: 900;
    letter-spacing: -0.05em;
  }
  @media (min-width: 768px) {
    .loader-text-container {
      font-size: 8rem;
    }
  }
  .loader-text {
    margin: 0;
    white-space: nowrap;
  }
  .loader-text.outline {
    color: transparent;
    -webkit-text-stroke: 2px rgba(255, 255, 255, 0.15);
  }
  .loader-text.solid {
    position: absolute;
    top: 0;
    left: 0;
    color: var(--clr-main);
    overflow: hidden;
    width: 0%;
    transition: width 0.3s ease-out;
  }
</style>
