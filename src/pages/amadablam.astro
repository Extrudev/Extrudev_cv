---
import SectionBase from "../components/amadablam/SectionBase.astro";
import SectionDominaElGrado from "../components/amadablam/SectionDominaElGrado.astro";
import SectionInstalaciones from "../components/amadablam/SectionInstalaciones.astro";
import SectionLaCima from "../components/amadablam/SectionLaCima.astro";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Club Alpino Ama Dablam | The Ultimate Ascent</title>
    <link rel="icon" type="image/svg" href="/amadablam/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@100..800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Watermark ExtruDev — centrado, no interactivo -->
    <div class="extrudev-watermark" aria-hidden="true">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="4 17 10 11 4 5"></polyline>
        <line x1="12" y1="19" x2="20" y2="19"></line>
      </svg>
    </div>

    <main id="climb-container">
      {/* Fondo dinámico con parallax */}
      <div id="dynamic-bg" class="bg-climb-wall"></div>

      {/* Navegación lateral (oculta en mobile) */}
      <nav class="fixed-nav">
        <ul class="nav-links">
          <li>
            <a href="#base" class="nav-item active" data-target="base">Base</a>
          </li>
          <li>
            <a href="#high" class="nav-item" data-target="high">Instalaciones</a
            >
          </li>
          <li>
            <a href="#low" class="nav-item" data-target="low">Domina el Grado</a
            >
          </li>
          <li>
            <a href="#summit" class="nav-item" data-target="summit">¡La Cima!</a
            >
          </li>
        </ul>
        {/* Barra de progreso */}
        <div class="progress-track">
          <div id="progress-bar" class="progress-bar"></div>
        </div>
      </nav>

      {/* Secciones */}
      <SectionLaCima />
      <SectionDominaElGrado />
      <SectionInstalaciones />
      <SectionBase />
    </main>

    <script>
      import Lenis from "lenis";

      const isDesktop = () =>
        window.innerWidth >= 1024 &&
        !window.matchMedia("(pointer: coarse)").matches;

      const container = document.getElementById(
        "climb-container",
      ) as HTMLElement;
      const bg = document.getElementById("dynamic-bg") as HTMLElement | null;
      const progressBar = document.getElementById(
        "progress-bar",
      ) as HTMLElement | null;
      const progressTrack = document.querySelector(
        ".progress-track",
      ) as HTMLElement | null;
      const sections = document.querySelectorAll("section");

      if (!container) throw new Error("climb-container no encontrado");

      function syncProgressTrackHeight() {
        const navItems = Array.from(
          document.querySelectorAll(".fixed-nav .nav-item"),
        ) as HTMLElement[];
        if (!progressTrack || navItems.length < 2) return;
        const first = navItems[0].getBoundingClientRect();
        const last = navItems[navItems.length - 1].getBoundingClientRect();
        const h = Math.abs(
          last.top + last.height / 2 - (first.top + first.height / 2),
        );
        progressTrack.style.height = `${h}px`;
      }

      function onScroll(scrollTop: number) {
        const totalHeight = container.scrollHeight - container.clientHeight;
        const scrollPercent = scrollTop / totalHeight;

        if (progressBar) {
          progressBar.style.height = `${(1 - scrollPercent) * 100}%`;
        }
        if (bg) {
          bg.style.backgroundPosition = `center ${scrollPercent * 100}%`;
        }
        sections.forEach((sec) => {
          const rect = sec.getBoundingClientRect();
          if (rect.top >= 0 && rect.top < window.innerHeight / 2) {
            updateNavActive(sec.getAttribute("id") || "base");
          }
        });
      }

      function updateNavActive(id: string) {
        document.querySelectorAll(".nav-item").forEach((item) => {
          item.classList.remove("active");
          if (item.getAttribute("data-target") === id)
            item.classList.add("active");
        });
      }

      document.querySelectorAll(".nav-item").forEach((item) => {
        item.addEventListener("click", (e) => {
          e.preventDefault();
          const targetId = item.getAttribute("data-target");
          if (!targetId) return;
          const targetEl = document.getElementById(targetId);
          if (!targetEl) return;

          if (lenis) {
            lenis.scrollTo(targetEl, { offset: 0 });
          } else {
            targetEl.scrollIntoView({ behavior: "smooth" });
          }
        });
      });

      let lenis: InstanceType<typeof Lenis> | null = null;
      let rafId = 0;

      function initLenis() {
        if (lenis) return;
        lenis = new Lenis({
          wrapper: container,
          duration: 1.8,
          wheelMultiplier: 0.3,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          smoothWheel: true,
        });
        lenis.on("scroll", ({ scroll }: { scroll: number }) =>
          onScroll(scroll),
        );

        function raf(time: number) {
          lenis!.raf(time);
          rafId = requestAnimationFrame(raf);
        }
        rafId = requestAnimationFrame(raf);
      }

      function destroyLenis() {
        if (!lenis) return;
        cancelAnimationFrame(rafId);
        lenis.destroy();
        lenis = null;
        container.addEventListener("scroll", nativeScroll);
      }

      function nativeScroll() {
        onScroll(container.scrollTop);
      }

      window.addEventListener("load", () => {
        setTimeout(() => {
          container.scrollTop = container.scrollHeight;
          syncProgressTrackHeight();
          if (isDesktop()) {
            initLenis();
          } else {
            container.addEventListener("scroll", nativeScroll);
          }
        }, 150);
      });

      window.addEventListener("resize", () => {
        syncProgressTrackHeight();
        if (isDesktop()) {
          container.removeEventListener("scroll", nativeScroll);
          initLenis();
        } else {
          destroyLenis();
          container.addEventListener("scroll", nativeScroll);
        }
      });
    </script>
  </body>
</html>

<style is:global>
  /* ── Fuentes ─────────────────────────────────────────── */
  @font-face {
    font-family: "Thunder-VF";
    src: url("/amadablam/font/Thunder-VF.ttf") format("truetype");
    font-weight: 100 900;
    font-style: normal;
    font-display: swap;
  }

  /* ── Reset anchors ───────────────────────────────────── */
  a,
  a:visited,
  a:hover,
  a:active {
    text-decoration: none;
    color: inherit;
  }

  :root {
    --clr-dark: #003049;
    --clr-contrast: #d62828;
    --clr-accent: #f77f00;
    --clr-main: #fcbf49;
    --clr-text: #ffffff;
    --clr-text-muted: rgba(255, 255, 255, 0.5);
    --clr-surface: rgba(0, 48, 73, 0.78);
    --clr-overlay: rgba(0, 0, 0, 0.45);
    --clr-border: rgba(255, 255, 255, 0.12);
    --font-display: "Thunder-VF", sans-serif;
    --font-body: "Sora", sans-serif;
    --nav-right: 2rem;
  }

  /* ── Reset ───────────────────────────────────────────── */
  html,
  body {
    height: 100%;
    margin: 0;
    padding: 0;
    overflow-x: hidden;
    font-family: var(--font-body);
    color: var(--clr-text);
    background-color: transparent;
  }

  /* ── Animaciones ─────────────────────────────────────── */
  @keyframes float {
    0% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-30px);
    }
    100% {
      transform: translateY(0px);
    }
  }

  .animate-float {
    animation: float 2s ease-in-out infinite;
  }

  /* ── Contenedor principal ────────────────────────────── */
  #climb-container {
    height: 100vh;
    overflow-y: scroll;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  #climb-container::-webkit-scrollbar {
    display: none;
  }

  /* ── Secciones ───────────────────────────────────────── */
  section {
    height: 100vh;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
  }

  /* ── Shared layout ───────────────────────────────────── */
  .content-container {
    max-width: 1152px;
    width: 100%;
    padding: 0 1.5rem;
    box-sizing: border-box;
  }
</style>

<style>
  /* ── Watermark ExtruDev ──────────────────────────────── */
  .extrudev-watermark {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 40vw;
    height: 40vh;
    z-index: 999;
    pointer-events: none;
    opacity: 0.4;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .extrudev-watermark svg {
    width: 100%;
    height: 100%;
  }

  /* ── Fondo dinámico ──────────────────────────────────── */
  .bg-climb-wall {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: url("/amadablam/bg-climb-wall.jpg");
    background-size: cover;
    background-position: center bottom;
    z-index: -2;
  }

  /* ── Navegación lateral derecha ──────────────────────── */
  .fixed-nav {
    position: fixed;
    right: var(--nav-right);
    top: 50%;
    transform: translateY(-50%);
    z-index: 50;
    display: flex;
    flex-direction: row;
    align-items: flex-end;
    gap: 1.25rem;
  }

  .nav-links {
    list-style: none;
    display: flex;
    flex-direction: column-reverse;
    gap: 8rem;
    margin: 0;
    padding: 0;
    text-align: right;
  }

  .nav-item {
    display: block;
    text-decoration: none;
    color: var(--clr-text-muted);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    white-space: nowrap;
    transition: all 0.3s ease;
  }

  .nav-item:hover {
    color: var(--clr-text);
  }

  .nav-item.active {
    color: var(--clr-main);
    font-weight: 700;
    scale: 1.25;
    transform-origin: right center;
  }

  /* ── Riel de progreso ────────────────────────────────── */
  .progress-track {
    position: relative;
    width: 5px;
    height: 450px;
    background-color: rgba(255, 255, 255, 0.15);
    border-radius: 2px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .progress-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 0%;
    background-color: var(--clr-main);
    border-radius: 2px;
    transition: height 0.15s ease;
  }

  /* ── Ocultar nav en mobile ───────────────────────────── */
  @media (max-width: 767px) {
    .fixed-nav {
      display: none;
    }
  }
</style>
