---
import Card from "./Card.astro";
const { lang = 'es' } = Astro.props;
const data = (await import("../data/data.json")).default as any;
const { formacion } = data[lang];
---

<section id="formacion" class="experience-section">
    <div class="container">
        <h2 class="section-title">
            <span>
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="var(--accent)"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    style="margin-right: 10px; vertical-align: middle;"
                    ><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"></path></svg
                >
                {lang === 'es' ? 'Formación:' : 'Education:'}
            </span>
        </h2>

        <div class="timeline">
            {
                formacion.map((exp: any) => (
                    <Card
                        date={exp.date}
                        title={exp.title}
                        subtitle={exp.subtitle}
                        link={exp.link}
                    />
                ))
            }
        </div>
    </div>
</section>

<style>
    .experience-section {
        padding: 6rem 0;
    }

    .container {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    .section-title {
        font-size: 2.2rem;
        margin-bottom: 5rem;
        text-align: left;
        color: var(--text);
    }

    .timeline {
        position: relative;
        border-left: 1px solid var(--primary);
        padding-left: 0;
        margin-left: 2rem;
    }
</style>
