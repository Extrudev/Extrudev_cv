---
// SectionLaCima.astro — Sección final / "La Cima"
---

<section id="summit" class="summit-section">
  <div class="content-container">
    <h1 class="top-badge">¡Has llegado a la cima!</h1>
  </div>
  <div class="content-container summit-grid">
    <div class="summit-text">
      <h2 class="section-title">La Cima</h2>
      <p class="summit-quote">
        «Las mejores vistas llegan tras la escalada más dura.»
      </p>
    </div>

    <div class="summit-right">
      <a
        href="https://maps.app.goo.gl/DotZusihTLH1V2K69"
        target="_blank"
        rel="noopener"
        class="map-link"
        aria-label="Ver en Google Maps"
      >
        <img
          src="/amadablam/map.jpg"
          alt="Mapa de localización del rocodromo El Tornillo, San Pedro Alcántara"
          class="map-img"
        />
      </a>
      <div class="location-info">
        <div class="location-row">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
          <span>Palacio de los Deportes Elena Benítez, San Pedro Alcántara</span
          >
        </div>
        <div class="location-row">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
          <span>Mar y Jue &nbsp;·&nbsp; 18:00 – 22:00</span>
        </div>
      </div>
      <button class="btn-outline">CONTACTA CON NOSOTROS</button>
    </div>
  </div>
  <footer class="main-footer">
    <span class="footer-copy"
      >&copy; {new Date().getFullYear()} Club Alpino Ama Dablam. Elevando el potencial
      humano.</span
    >
    <div class="site-by">
      Site by
      <a href="https://extrudev.com" target="_blank" rel="noopener">
        EXTRUDEV
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="1rem"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="feather feather-terminal"
        >
          <polyline points="4 17 10 11 4 5"></polyline>
          <line x1="12" y1="19" x2="20" y2="19"></line>
        </svg>
      </a>
    </div>
  </footer>
</section>

<style>
  .summit-section {
    justify-content: flex-start;
    padding-top: 3rem;
    box-sizing: border-box;
  }

  .section-title {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 2rem;
    text-align: center;
  }

  @media (min-width: 768px) {
    .section-title {
      font-size: 3rem;
      text-align: left;
    }
  }

  .summit-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .summit-grid {
      gap: 20rem;
      grid-template-columns: repeat(2, 1fr);
      align-items: start;
    }
  }

  /* ── Right column ── */
  .summit-right {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .map-link {
    display: block;
    overflow: hidden;
    border: 2px solid rgba(255, 255, 255, 0.1);
  }

  .map-img {
    display: block;
    width: 100%;
    height: 360px;
    object-fit: cover;
  }

  .location-info {
    background-color: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(4px);
    border-left: 3px solid var(--clr-main);
    padding: 0.65rem 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .location-row {
    display: flex;
    align-items: flex-start;
    gap: 0.4rem;
    font-size: 0.78rem;
    color: #e5e7eb;
    line-height: 1.4;
  }

  .location-row svg {
    flex-shrink: 0;
    margin-top: 1px;
    color: var(--clr-main);
  }

  .summit-text {
    text-align: center;
  }

  @media (min-width: 768px) {
    .summit-text {
      text-align: left;
    }
  }

  .top-badge {
    display: table;
    margin: 0 auto 5rem auto;
    font-weight: 900;
    font-size: 4rem;
    text-transform: uppercase;
  }

  .summit-quote {
    font-size: 1.25rem;
    font-style: italic;
    color: #d1d5db;
    margin-bottom: 2rem;
  }

  @media (min-width: 768px) {
    .summit-quote {
      font-size: 1.5rem;
    }
  }

  .btn-secondary {
    padding: 1rem 2.5rem;
    background-color: #fff;
    color: #000;
    font-weight: 900;
    font-size: 1.125rem;
    text-decoration: none;
    transition:
      background-color 0.3s,
      color 0.3s;
    border: none;
    cursor: pointer;
    border-radius: 4px;
  }

  .btn-secondary:hover {
    background-color: var(--clr-main);
  }

  .summit-contact {
    background-color: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    padding: 2rem;
    border-left: 4px solid var(--clr-main);
  }

  .summit-contact h3 {
    color: #9ca3af;
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }

  .btn-outline {
    width: 100%;
    padding: 1rem;
    border: 1px solid #fff;
    background: transparent;
    color: #fff;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.5rem;
    letter-spacing: 0.3em;
    transition: all 0.3s;
    cursor: pointer;
    border-radius: 4px;
  }

  .btn-outline:hover {
    background-color: #fff;
    color: #000;
  }

  .main-footer {
    position: absolute;
    bottom: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1.25rem 2rem;
    border-top: 1px solid var(--clr-main);
    color: var(--clr-main);
    font-size: 0.85rem;
    box-sizing: border-box;
  }

  .footer-copy {
    text-align: center;
  }

  .site-by {
    display: flex;
    align-items: center;
    gap: 0.2rem;
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.45);
    white-space: nowrap;
  }

  .site-by a {
    display: flex;
    align-items: center;
    gap: 0.2rem;
    color: rgba(255, 255, 255, 0.45);
    font-weight: 700;
    transition: color 0.3s;
  }

  .site-by a:hover {
    color: var(--clr-main);
  }
</style>
