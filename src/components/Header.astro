---
const { personalInfo } = (await import("../data/data.json")).default;
---

<header class="main-header">
  <div class="header-content">
    <div class="logo-container">
      <a href="#" class="logo">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="1.5rem"
          height="1.5rem"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="feather feather-terminal"
        >
          <polyline points="4 17 10 11 4 5"></polyline>
          <line x1="12" y1="19" x2="20" y2="19"></line>
        </svg>
        <span class="logo-text">ExtruDev</span>
      </a>
    </div>

    <nav class="nav-links">
      <a href="#top">[Home]</a>
      <a href="#experience">[Experiencia]</a>
      <a href="#contact">[Contacto]</a>
    </nav>
  </div>
</header>

<style>
  .main-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    padding: 1rem 0;
    background: var(--header);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .header-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo-container {
    display: flex;
    align-items: center;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: "Onest", sans-serif;
    font-size: 1.2rem;
    font-weight: 400;
    color: #fff;
    transition: var(--transition-smooth);
  }

  .logo-container:hover .logo {
    color: var(--logo);
  }

  .logo-text {
    color: inherit;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
  }

  .nav-links a {
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--text);
    position: relative;
  }

  .nav-links a:hover {
    color: var(--logo);
  }

  @media (max-width: 425px) {
    .nav-links {
      display: none;
    }
  }
</style>
