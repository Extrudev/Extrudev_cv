---
const { lang = "es" } = Astro.props;
const data = (await import("../data/data.json")).default as any;
const { personalInfo } = data[lang];
const roleDynamic = personalInfo.role.replace(
    "{{YEARS}}",
    new Date().getFullYear() - 2023,
);
---

<section id="top" class="hero">
    <div class="hero-container">
        <div class="avatar-header">
            <div class="avatar-img">
                <img src="/img/avatar.png" alt="avatar" />
            </div>
            <h1
                class="hero-title"
                id="typewriter-title"
                data-part1={lang === "es" ? "¡Hola! Soy Luis" : "Hi! I'm Luis"}
            >
                <span id="tw-text-1"></span><span
                    class="header-name"
                    id="tw-text-2"></span>
            </h1>
        </div>

        <div class="role-container">
            <h2 class="hero-role">{roleDynamic}</h2>
        </div>

        <div class="hero-desc">
            <span class="syntax-bracket">[</span>
            <span class="syntax-bracket">{personalInfo.description}</span>
            <span class="syntax-bracket">]</span>
            <span class="syntax-arrow">=&gt;</span>
            <span class="syntax-arrow">(</span>
            {lang === "es" ? "Residente en " : "Based in "}
            <span class="syntax-arrow">{personalInfo.location}</span>.
            <span class="syntax-arrow">)</span>
        </div>

        <div class="status-badge">
            <span class="status-dot"></span>
            {lang === "es" ? "Actualmente Disponible" : "Currently Available"}
        </div>

        <div class="hero-actions">
            <a
                href={personalInfo.socials.github}
                target="_blank"
                class="btn-premium"
            >
                GitHub
            </a>
            <a href="#contact" class="btn-premium">
                {lang === "es" ? "Contáctame" : "Contact me"}
            </a>
        </div>
    </div>
</section>

<style>
    .avatar-header {
        display: flex;
        align-items: center;
        gap: 2rem;
        margin-bottom: 2rem;
    }

    .avatar-img {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        overflow: hidden;
        flex-shrink: 0;
    }
    .avatar-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .hero {
        min-height: 60vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding-top: 100px;
    }

    .hero-container {
        max-width: 900px;
        text-align: left;
        padding: 0 2rem;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 0.8rem;
        background: rgba(137, 202, 120, 0.1);
        border: 1px solid var(--secondary);
        border-radius: 4px;
        font-size: 0.75rem;
        color: var(--secondary);
        margin-block: 2rem;
    }

    .status-dot {
        width: 6px;
        height: 6px;
        background: var(--secondary);
        border-radius: 50%;
    }

    .hero-title {
        font-family: var(--font-main);
        font-size: 3.5rem;
        font-weight: 700;
        margin-bottom: 0;
        color: var(--text);
        border-right: 4px solid var(--primary);
        display: inline-block;
        padding-right: 8px;
        animation: blink-caret 0.75s step-end infinite;
        word-break: break-word;
    }

    .role-container {
        display: block;
        margin-bottom: 2rem;
    }

    .hero-role {
        font-size: 1.5rem;
        color: var(--text);
        font-weight: 400;
    }

    .hero-desc {
        font-size: 1.2rem;
        line-height: 1.7;
        color: var(--text);
        word-wrap: break-word;
        max-width: 100%;
    }

    .syntax-bracket {
        color: var(--logo);
    }
    .syntax-string {
        color: var(--secondary);
    }
    .syntax-arrow {
        color: var(--accent);
    }
    .syntax-location {
        color: var(--logo);
    }

    .hero-actions {
        display: flex;
        gap: 1rem;
    }

    @media (max-width: 768px) {
        .avatar-header {
            flex-direction: column;
            gap: 1rem;
            text-align: center;
        }

        .avatar-img {
            width: 100px;
            height: 100px;
        }

        .hero-title {
            font-size: 2rem;
        }

        .hero-role {
            font-size: 1.1rem;
        }

        .hero-desc {
            font-size: 1rem;
        }
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const title = document.getElementById("typewriter-title");
        if (!title) return;

        const part1 = title.getAttribute("data-part1") || "";
        const part2 = title.getAttribute("data-part2") || "";
        const span1 = document.getElementById("tw-text-1");
        const span2 = document.getElementById("tw-text-2");

        if (span1) span1.textContent = "";
        if (span2) span2.textContent = "";

        const fullText = part1 + part2;
        let i = 0;
        const speed = 60; // ms per char

        function typeWriter() {
            if (i < fullText.length) {
                if (i < part1.length) {
                    if (span1) span1.textContent += fullText.charAt(i);
                } else {
                    if (span2) span2.textContent += fullText.charAt(i);
                }
                i++;
                setTimeout(typeWriter, speed);
            }
        }

        // Pequeño retraso inicial para que se vea el efecto
        setTimeout(typeWriter, 300);
    });
</script>
